    USERS ||--o{ COLLECTIONS : "possède"
    USERS ||--o{ SESSIONS : "organise"
    USERS ||--o{ MESSAGES : "envoie"
    USERS ||--o{ INVITATIONS : "reçoit"
    USERS ||--o{ VOTES : "vote"

    GAMES ||--o{ COLLECTIONS : "est ajouté à"
    GAMES ||--o{ SESSIONS : "est joué dans"
    GAMES ||--o{ GAME_TAGS : "est catégorisé par"
    GAMES ||--o{ GAME_PLATFORMS : "est disponible sur"
    GAMES ||--o{ VOTES : "est voté pour"

